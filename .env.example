# Subdominio que vai apontar para o IP da VPS.
APP_DOMAIN=calculadora.seudominio.com.br

# Senha de acesso do app.
APP_PASSWORD=troque-por-uma-senha-forte

# Ajustes para lotes grandes. Comece conservador e aumente se a VPS tiver RAM.
ADVREAJUSTE_PDF_WORKERS=2
ADVREAJUSTE_OCR_WORKERS=1
ADVREAJUSTE_OCR_DPI=150
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=2048

# Cache/dados dentro do volume Docker persistente.
ADVREAJUSTE_DATA_DIR=/var/data
ADVREAJUSTE_OCR_CACHE_DIR=/var/data/cache/ocr
ADVREAJUSTE_LOG_LEVEL=INFO
ADVREAJUSTE_USE_BATCH=false

# IA fica opcional. O pipeline principal e OCR rodam offline.
# ADVREAJUSTE_GEMINI_API_KEY=
# ADVREAJUSTE_ANTHROPIC_API_KEY=
